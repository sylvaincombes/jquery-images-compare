{
  "name": "jquery-images-compare",
  "version": "4.0.0",
  "description": "jQuery plugin to compare two images with a draggable before/after slider",
  "keywords": [
    "jquery",
    "plugin",
    "image-compare",
    "image-slider",
    "before-after",
    "before-after-slider",
    "slider",
    "compare",
    "before",
    "after",
    "drag",
    "responsive",
    "touch"
  ],
  "main": "build/jquery.images-compare.js",
  "files": [
    "build/",
    "README.md",
    "LICENSE.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sylvaincombes/jquery-images-compare.git"
  },
  "bugs": {
    "url": "https://github.com/sylvaincombes/jquery-images-compare/issues"
  },
  "dependencies": {
    "jquery": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.3",
    "esbuild": "^0.25.9"
  },
  "scripts": {
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "copy:js": "cp ./src/assets/js/jquery.images-compare.js ./build/jquery.images-compare.js",
    "minify:js": "esbuild ./src/assets/js/jquery.images-compare.js --minify --sourcemap --outfile=./build/jquery.images-compare.min.js",
    "copy:css": "cp ./src/assets/css/images-compare.css ./build/images-compare.css",
    "minify:css": "esbuild ./src/assets/css/images-compare.css --minify --outfile=./build/images-compare.min.css",
    "build": "bun run lint && bun run copy && bun run minify",
    "copy": "bun run copy:js && bun run copy:css",
    "minify": "bun run minify:js && bun run minify:css",
    "test": "echo \"Run 'bun run test:serve' then open http://localhost:41721/src/tests/test.html\"",
    "test:serve": "bunx serve . --listen 41721",
    "test:open": "bunx serve . --listen 41721 & bun run scripts/open-url.js http://localhost:41721/src/tests/test.html",
    "example:serve": "bunx serve . --listen 41721",
    "example:open": "bunx serve . --listen 41721 & bun run scripts/open-url.js http://localhost:41721/examples/index.html"
  },
  "author": "Sylvain Combes <combes.sylvain@gmail.com> (http://www.sylvaincombes.com)",
  "contributors": [
    "Audrey Soulagnet <me@drey.io> (http://drey.io)",
    "Céline Skowron <skowron.celine@gmail.com> (http://celine-skowron.fr)",
    "Iván Pérez (https://github.com/Ivan-Perez)"
  ],
  "license": "MIT"
}
